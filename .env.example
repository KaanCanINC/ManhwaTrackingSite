# -------------------------------------------------------
# Host volume paths (CasaOS defaults)
# -------------------------------------------------------
IMAGE=ghcr.io/kaancaninc/mancon:latest
HOST_DB_DIR=/var/lib/casaos/appdata/mancon/database
HOST_BACKUPS_DIR=/var/lib/casaos/appdata/mancon/backups
HOST_IMPORTS_DIR=/var/lib/casaos/appdata/mancon/imports

# -------------------------------------------------------
# Container user (match your host UID/GID — run `id` to check)
# -------------------------------------------------------
PUID=1000
PGID=1000

# -------------------------------------------------------
# App settings
# -------------------------------------------------------
# Port exposed on the host
PORT=3000

# Maximum number of backup snapshots to keep before rotating
MAX_BACKUPS=60

# -------------------------------------------------------
# Enrichment settings (optional)
# -------------------------------------------------------
# Minimum match confidence for MAL/AniList metadata (0.0–1.0)
ENRICH_MIN_CONFIDENCE=0.72

# Delay between enrichment requests in ms (avoid rate limits)
ENRICH_DELAY_MS=600

# Maximum enrichment fetch retries per job
ENRICH_MAX_RETRIES=3

# Delay between job worker loops in ms
ENRICH_LOOP_DELAY_MS=500
